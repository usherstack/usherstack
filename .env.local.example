# LOCAL DEVELOPMENT - Copy to .env.local and customize

# Backend API URL (points to local backend during development)
VITE_API_URL=http://localhost:10000

# Feature Flags
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_PROJECTS=true

# Optional: Analytics
# VITE_GOOGLE_ANALYTICS_ID=

# Optional: Calendly Integration
# VITE_CALENDLY_URL=https://calendly.com/your-username
